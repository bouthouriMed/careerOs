{
  "manifest_version": 3,
  "name": "CareerOS — Save Jobs",
  "description": "Save job postings to CareerOS with one click. Automatically extracts job title, company, salary, and more.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "http://localhost:4000/*"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Save to CareerOS"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/jobs/*",
        "https://*.indeed.com/*",
        "https://*.greenhouse.io/jobs/*",
        "https://*.lever.co/jobs/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
